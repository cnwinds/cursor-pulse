# 钉钉企业内部应用（复制为 .env 并填写，勿提交 Git）
DINGTALK_APP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# 机器人 ID（开放平台 → 机器人 → 机器人 ID，通常以 ding 开头）
DINGTALK_ROBOT_CODE=
# 钉钉群号（chatId，如 160490040796）；API 群发需 openConversationId
DINGTALK_CHAT_ID=
# openConversationId（cid...==）；可留空，首次 @机器人 后自动写入 data/dingtalk_group.json
DINGTALK_GROUP_ID=
# 管理员钉钉 userid，逗号分隔（未配置时所有人拥有管理员权限）
DINGTALK_ADMIN_USER_IDS=

# LLM（报告洞察层，可选）
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
VISION_ENABLED=false
VISION_MODEL=

# Web 管理后台
ADMIN_WEB_TOKEN=
JWT_SECRET=
DINGTALK_OAUTH_REDIRECT_URI=http://localhost:5173/login/callback
WEB_CORS_ORIGINS=http://localhost:5173

# 多团队（同一数据库多团队隔离；单团队可保持 default）
PULSE_TEAM_SLUG=default

# FinOps / BI Webhook
BI_WEBHOOK_URL=
BI_WEBHOOK_SECRET=

# Postgres（docker-compose.postgres.yml）
DATABASE_URL=

# S3 / MinIO 对象存储
S3_ENABLED=false
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Cursor Teams Admin API（可选，与 CSV 并存）
CURSOR_TEAMS_API_KEY=

# 32-byte base64 or hex key for encrypting Cursor API Keys
PULSE_CREDENTIAL_ENCRYPTION_KEY=

# 群平台（默认 dingtalk）
BOT_PLATFORM=dingtalk
