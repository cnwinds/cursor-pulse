# 钉钉企业内部应用（复制为 .env 并填写，勿提交 Git）
DINGTALK_APP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# 机器人 ID（开放平台 → 机器人 → 机器人 ID，通常以 ding 开头）
DINGTALK_ROBOT_CODE=
# 钉钉群号（chatId，示例：000000000000）；API 群发需 openConversationId
DINGTALK_CHAT_ID=
# openConversationId（cid...==）；可留空，首次 @机器人 后自动写入 team_settings.dingtalk（pulse.db）
DINGTALK_GROUP_ID=
# 管理员钉钉 userid，逗号分隔（留空表示无管理员）
DINGTALK_ADMIN_USER_IDS=

# LLM（报告洞察层，可选）
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
VISION_ENABLED=false
VISION_MODEL=

# Web 管理后台
ADMIN_WEB_TOKEN=
ADMIN_PASSWORD=
JWT_SECRET=
DINGTALK_OAUTH_REDIRECT_URI=http://localhost:5173/login/callback
WEB_CORS_ORIGINS=http://localhost:5173

# 多团队（同一数据库多团队隔离；单团队可保持 default）
PULSE_TEAM_SLUG=default

# FinOps / BI Webhook
BI_WEBHOOK_URL=
BI_WEBHOOK_SECRET=

# Postgres（docker-compose.postgres.yml）
DATABASE_URL=

# S3 / MinIO 对象存储
S3_ENABLED=false
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Cursor Teams Admin API（可选，与 CSV 并存）
CURSOR_TEAMS_API_KEY=

# 32-byte base64 or hex key for encrypting Cursor API Keys
PULSE_CREDENTIAL_ENCRYPTION_KEY=

# 群平台（默认 dingtalk）
BOT_PLATFORM=dingtalk

# 用量提交催办（收集开始群通知 / 每日私聊催交 / 截止日 @全员）；默认关闭
# USAGE_REMINDERS_ENABLED=true

# Pulse internal Capability Provider API（Assistant 调用；未配置则拒绝所有 internal 请求）
PULSE_INTERNAL_SERVICE_TOKEN=

# Cursor 代理客户端可达地址（写入一键复制命令的 HTTPS_PROXY）
PROXY_PUBLIC_URL=http://127.0.0.1:8317

# Go 代理访问 Cursor 上游时使用的出站代理（翻墙）；空=直连。勿与客户端 HTTPS_PROXY 混淆。
# 支持无认证与 Basic 认证：
# PROXY_UPSTREAM_URL=http://127.0.0.1:7890
# PROXY_UPSTREAM_URL=http://user:pass@127.0.0.1:7890

# 用量/模型旁路诊断：开启后打全量候选字符串，并落盘请求体到 ~/.cursor-quota-proxy/debug-usage/
# PROXY_DEBUG_USAGE=1
# PROXY_DEBUG_USAGE_DIR=/path/to/.dev/proxy-debug-usage

# 联网搜索（Tavily；仅 Pulse 配置层读取，勿写入 Assistant 日志/会话）
# TAVILY_API_KEY=
# TAVILY_SEARCH_URL=https://api.tavily.com/search
# WEB_SEARCH_ENABLED=false
# WEB_SEARCH_TIMEOUT_SECONDS=10
# WEB_SEARCH_MAX_RESULTS=5

# Assistant Platform 旁路（Phase 0；默认关闭）
ASSISTANT_MIRROR_ENABLED=false
ASSISTANT_MIRROR_BASE_URL=http://127.0.0.1:8090
ASSISTANT_SERVICE_TOKEN=
ASSISTANT_DATABASE_URL=sqlite:///data/assistant.db
ASSISTANT_PORT=8090
# Secret Store（生产必须独立高熵密钥，勿复用 service token）
ASSISTANT_SECRET_KEY=

# Assistant Platform 能力桥（Phase 1；默认关闭，失败回退 legacy）
# CAPABILITY_BRIDGE_QUOTA_SELF_READ=false
# CAPABILITY_BRIDGE_CURSOR_KEY_BIND=false
# CAPABILITY_BRIDGE_GUIDE_IMAGE_UPDATE=false

# Assistant Platform LLM（可选）
ASSISTANT_LLM_ENABLED=false
ASSISTANT_LLM_API_KEY=
ASSISTANT_LLM_BASE_URL=https://api.openai.com/v1
ASSISTANT_LLM_MODEL=
