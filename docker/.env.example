# ── 钉钉（必填）────────────────────────────────────────────────────────────
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_GROUP_ID=
DINGTALK_ADMIN_USER_IDS=

# ── Web 管理后台（生产必填）──────────────────────────────────────────────────
JWT_SECRET=
ADMIN_WEB_TOKEN=
# 对外访问域名（用于 OAuth / CORS；生产改为实际域名）
DINGTALK_OAUTH_REDIRECT_URI=https://your-domain.com/admin/login/callback
WEB_CORS_ORIGINS=https://your-domain.com

# ── 团队隔离 ────────────────────────────────────────────────────────────────
PULSE_TEAM_SLUG=default

# ── 宿主机映射端口 ──────────────────────────────────────────────────────────
PULSE_WEB_PORT=8080

# ── 容器间通信（Docker 网络内服务名，一般勿改）──────────────────────────────
ASSISTANT_MIRROR_ENABLED=true
ASSISTANT_MIRROR_BASE_URL=http://assistant:8090
# 下列令牌勿使用 change-me；运行 scripts/setup.sh 会自动生成
ASSISTANT_SERVICE_TOKEN=
PULSE_INTERNAL_SERVICE_TOKEN=
PULSE_INTERNAL_TOKEN=
PULSE_BASE_URL=http://web:8080

# Assistant 加密密钥（与本地迁移时必须一致，否则 ap_secrets 无法解密）
ASSISTANT_SECRET_KEY=
PULSE_CREDENTIAL_ENCRYPTION_KEY=

# ── Assistant LLM（可选）──────────────────────────────────────────────────
ASSISTANT_LLM_ENABLED=false
ASSISTANT_LLM_API_KEY=
ASSISTANT_LLM_BASE_URL=https://api.openai.com/v1
ASSISTANT_LLM_MODEL=

# ── 联网搜索（可选，Tavily）────────────────────────────────────────────────
# TAVILY_API_KEY=
# WEB_SEARCH_ENABLED=false

# ── Postgres 可选（配合 docker-compose.postgres.yml）────────────────────────
# POSTGRES_DB=pulse
# POSTGRES_USER=pulse
# POSTGRES_PASSWORD=
# DATABASE_URL=postgresql+psycopg://pulse:password@db:5432/pulse
